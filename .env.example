ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...                 # Phase 2: household knowledge base embeddings (Cohere Embed v4)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_WEBHOOK_SECRET=some-long-random-string
DATABASE_URL=postgresql://...      # on Railway, set as a reference: ${{Postgres.DATABASE_URL}} (not auto-shared)
TIMEZONE=Africa/Cairo

# Phase 3 — shared Google Calendar (read-only via service account) + live location
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # the full JSON key, as one string
GOOGLE_CALENDAR_ID=...@group.calendar.google.com
HOME_LAT=30.0000                   # drop a pin on your building in Google Maps
HOME_LNG=31.0000

# Phase 4 — Egyptian voice over Telegram (ElevenLabs: Scribe STT + Flash v2.5 TTS)
ELEVENLABS_API_KEY=...             # one key covers both STT and TTS
TTS_VOICE_ID=...                   # audition/clone a CAIRENE voice — the default Arabic leans Gulf
TTS_MODEL=eleven_flash_v2_5        # fastest (~75ms), half the credits
STT_MODEL=scribe_v1                # scribe_v2 also available
STT_LANGUAGE=ar                    # Arabic (expect English code-switching)
VOICE_REPLIES=true                 # reply with voice when the user sent voice
REPLY_TEXT_ALONGSIDE_VOICE=true    # send text first (instant), then the voice note
MAX_VOICE_SECONDS=60               # ignore voice notes longer than this
